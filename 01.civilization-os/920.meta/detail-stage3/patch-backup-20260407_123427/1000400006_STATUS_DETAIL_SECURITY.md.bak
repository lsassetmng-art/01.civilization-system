# ============================================================
# STATUS DETAIL SECURITY
# ============================================================

status: canonical
layer: security
domain: detail
subdomain: status-detail
system: civilization-os
owner: Boss
prepared_by: Zero

purpose:
Defines security rules for status detail.

security_focus:
- root-cause masking
- critical-status restricted access
- incident-history control
- recovery-link disclosure control

actor_matrix:
- public -> public alert summary only
- internal -> operational detail as authorized
- restricted_operator -> internal root cause as authorized
- audit -> incident history as authorized

failure_codes:
- STATUS_DETAIL_SECURITY_SCOPE_DENIED
- STATUS_DETAIL_SECURITY_CAUSE_MASK_REQUIRED
- STATUS_DETAIL_SECURITY_CRITICAL_SCOPE_DENIED
