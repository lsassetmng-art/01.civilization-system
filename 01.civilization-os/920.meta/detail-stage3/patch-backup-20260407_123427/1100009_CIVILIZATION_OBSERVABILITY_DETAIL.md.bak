status: canonical
layer: 110.infrastructure
system: civilization-os
owner: Boss
prepared_by: Zero

purpose:
Define detailed observability requirements.

observability_targets:
- sync consume path
- sync dispatch path
- retry path
- dead-letter path
- approval path
- audit path

required_fields:
- correlation_id
- causation_id where applicable
- source_state_version where applicable
- error_code
- error_message
- created_at
- updated_at
