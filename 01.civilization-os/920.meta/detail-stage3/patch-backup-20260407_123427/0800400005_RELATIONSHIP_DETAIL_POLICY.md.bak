# ============================================================
# RELATIONSHIP DETAIL POLICY
# ============================================================

status: canonical
layer: policy
domain: detail
subdomain: relationship-detail
system: civilization-os
owner: Boss
prepared_by: Zero

purpose:
Defines policy rules for relationship detail.

policy_focus:
- public relation summary boundaries
- internal trust nuance restriction
- historical relation disclosure rules
- broken relation retention rules

disclosure_matrix:
- public_relation_summary: public allowed
- internal_trust_detail: public denied
- broken_relation_history: history/audit mode only
- sealed_relation_detail: explicit authority required

validation_rules:
- internal trust nuance must not appear in public-safe output.
- broken relation history must remain historical only.
