# ============================================================
# ACTIVITY DETAIL SECURITY
# ============================================================

status: canonical
layer: security
domain: detail
subdomain: activity-detail
system: civilization-os
owner: Boss
prepared_by: Zero

purpose:
Defines security rules for activity detail.

security_focus:
- execution-detail authorization
- blocked-reason masking
- support versus operator scope control
- training versus execution separation

actor_matrix:
- general_internal -> training_guidance only
- operator -> execution_detail as authorized
- supervisor -> blocked_reason as authorized
- audit -> historical execution detail as authorized

failure_codes:
- ACTIVITY_DETAIL_SECURITY_SCOPE_DENIED
- ACTIVITY_DETAIL_SECURITY_BLOCK_REASON_MASK_REQUIRED
- ACTIVITY_DETAIL_SECURITY_EXECUTION_SCOPE_DENIED
