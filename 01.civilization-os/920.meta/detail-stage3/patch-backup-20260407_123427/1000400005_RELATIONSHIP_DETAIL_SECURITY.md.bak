# ============================================================
# RELATIONSHIP DETAIL SECURITY
# ============================================================

status: canonical
layer: security
domain: detail
subdomain: relationship-detail
system: civilization-os
owner: Boss
prepared_by: Zero

purpose:
Defines security rules for relationship detail.

security_focus:
- trust-detail restriction
- public-safe relation exposure
- historical relation access control
- sealed relation-detail access control

actor_matrix:
- public -> relation_summary only
- internal -> internal trust nuance as authorized
- high_trust -> sealed relation detail as authorized
- audit -> broken/historical relation detail as authorized

failure_codes:
- RELATIONSHIP_DETAIL_SECURITY_SCOPE_DENIED
- RELATIONSHIP_DETAIL_SECURITY_TRUST_MASK_REQUIRED
- RELATIONSHIP_DETAIL_SECURITY_SEALED_DENIED
