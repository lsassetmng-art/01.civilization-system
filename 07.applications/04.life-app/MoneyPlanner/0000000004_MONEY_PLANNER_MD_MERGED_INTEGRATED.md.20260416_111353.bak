# ============================================================
# MONEY PLANNER OPERATIONS OVERVIEW
# ============================================================

status: canonical-draft
system: civilization-system
application_layer: 07.applications/04.life-app
app: MoneyPlanner
schema: life
layer: 070.operations
owner: Boss
prepared_by: Zero

layer_purpose:
