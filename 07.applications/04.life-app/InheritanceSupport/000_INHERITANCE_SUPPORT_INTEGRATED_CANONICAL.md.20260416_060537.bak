layer: 080.policy
subfolder: 010.core
owner: Boss
prepared_by: Zero

policies:
  legal_boundary:
    - 法的助言の代替ではない
    - 最終判断は本人または専門家
  sharing:
    - 家族共有は許可ベース
    - 不要な自動共有をしない
  ai:
    - 論点整理のみ
    - 断定表現を禁止する
  export:
    - 正式意見書出力を行わない
    - 正式相続書面の正本にはしない

